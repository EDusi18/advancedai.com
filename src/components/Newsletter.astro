---
---

<div class="newsletter">
	<h3>Stay Ahead of the AI Curve</h3>
	<p>Get weekly insights on AI tools, trends, and strategies delivered to your inbox.</p>
	<form class="newsletter-form" action="#" method="POST">
		<input
			type="email"
			name="email"
			placeholder="your@email.com"
			required
			aria-label="Email address"
		/>
		<button type="submit">Subscribe</button>
	</form>
	<p class="newsletter-note">Free. No spam. Unsubscribe anytime.</p>
</div>

<style>
	.newsletter {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2em;
		text-align: center;
		margin: 2em 0;
	}
	.newsletter h3 {
		margin-bottom: 0.5em;
		font-size: 1.5em;
	}
	.newsletter p {
		color: var(--text-secondary);
		margin-bottom: 1em;
	}
	.newsletter-form {
		display: flex;
		gap: 0.5em;
		max-width: 450px;
		margin: 0 auto;
	}
	.newsletter-form input {
		flex: 1;
		padding: 0.75em 1em;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--bg);
		color: var(--text);
		font-size: 1em;
	}
	.newsletter-form button {
		padding: 0.75em 1.5em;
		background: var(--accent);
		color: #fff;
		border: none;
		border-radius: 8px;
		font-weight: 700;
		cursor: pointer;
		font-size: 1em;
		transition: background 0.2s;
	}
	.newsletter-form button:hover {
		background: var(--accent-dark);
	}
	.newsletter-note {
		font-size: 0.8em;
		margin-top: 0.5em;
		margin-bottom: 0;
	}
	@media (max-width: 480px) {
		.newsletter-form {
			flex-direction: column;
		}
	}
</style>
