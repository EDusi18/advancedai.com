---
---

<div class="newsletter">
	<h3>Stay Ahead of the AI Curve</h3>
	<p>Get weekly insights on AI tools, trends, and strategies delivered to your inbox.</p>
	<form class="newsletter-form" id="nl-form" onsubmit="handleSubscribe(event)">
		<input
			type="email"
			name="email"
			id="nl-email"
			placeholder="your@email.com"
			required
			aria-label="Email address"
		/>
		<button type="submit" id="nl-btn">Subscribe</button>
	</form>
	<p class="newsletter-note" id="nl-msg">Free. No spam. Unsubscribe anytime.</p>
</div>

<script is:inline>
document.querySelectorAll('.newsletter-form').forEach(function(form) {
	form.addEventListener('submit', async function(e) {
		e.preventDefault();
		const emailInput = form.querySelector('input[type="email"]');
		const btn = form.querySelector('button[type="submit"]');
		const msg = form.closest('.newsletter').querySelector('.newsletter-note');
		const email = emailInput.value.trim();
		btn.textContent = 'Subscribing…';
		btn.disabled = true;
		try {
			const body = new URLSearchParams({ email: email, name: '' });
			const res = await fetch('https://forms.advancedai.com/subscribe', {
				method: 'POST',
				headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
				body: body.toString()
			});
			const json = await res.json();
			if (json.ok) {
				form.style.display = 'none';
				msg.textContent = '✅ You’re subscribed! Check your inbox.';
				msg.style.color = 'var(--accent)';
				msg.style.fontWeight = '600';
			} else {
				throw new Error(json.error || 'Failed');
			}
		} catch (err) {
			msg.textContent = 'Something went wrong — please try again.';
			msg.style.color = 'red';
			btn.textContent = 'Subscribe';
			btn.disabled = false;
		}
	});
});
</script>

<style>
	.newsletter {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2em;
		text-align: center;
		margin: 2em 0;
	}
	.newsletter h3 {
		margin-bottom: 0.5em;
		font-size: 1.5em;
	}
	.newsletter p {
		color: var(--text-secondary);
		margin-bottom: 1em;
	}
	.newsletter-form {
		display: flex;
		gap: 0.5em;
		max-width: 450px;
		margin: 0 auto;
	}
	.newsletter-form input {
		flex: 1;
		padding: 0.75em 1em;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--bg);
		color: var(--text);
		font-size: 1em;
	}
	.newsletter-form button {
		padding: 0.75em 1.5em;
		background: var(--accent);
		color: #fff;
		border: none;
		border-radius: 8px;
		font-weight: 700;
		cursor: pointer;
		font-size: 1em;
		transition: background 0.2s;
	}
	.newsletter-form button:hover {
		background: var(--accent-dark);
	}
	.newsletter-note {
		font-size: 0.8em;
		margin-top: 0.5em;
		margin-bottom: 0;
	}
	@media (max-width: 480px) {
		.newsletter-form {
			flex-direction: column;
		}
	}
</style>
