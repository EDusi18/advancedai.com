---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<button class="mobile-menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="3" y1="12" x2="21" y2="12"></line>
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="18" x2="21" y2="18"></line>
			</svg>
		</button>
		<div class="nav-links" id="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/briefings">Briefings</HeaderLink>
			<HeaderLink href="/analysis">Analysis</HeaderLink>
			<HeaderLink href="/tools">Tools</HeaderLink>
			<HeaderLink href="/categories">Categories</HeaderLink>
			<HeaderLink href="/guides/ai-for-executives">Executive Guide</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="nav-right">
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--header-bg);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 64px;
	}
	.site-title {
		font-weight: 700;
		font-size: 1.25em;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
	}
	.site-title:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.nav-links {
		display: flex;
		gap: 0.25em;
	}
	.nav-links :global(a) {
		padding: 0.5em 0.75em;
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.9em;
		border-radius: 6px;
		transition: color 0.2s, background 0.2s;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--accent);
		background: var(--bg-secondary);
		text-decoration: none;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.mobile-menu-toggle {
		display: none;
		background: none;
		border: none;
		color: var(--text);
		cursor: pointer;
		padding: 0.25em;
	}
	@media (max-width: 860px) {
		.mobile-menu-toggle {
			display: flex;
		}
		.nav-links {
			display: none;
			position: absolute;
			top: 64px;
			left: 0;
			right: 0;
			background: var(--bg);
			border-bottom: 1px solid var(--border);
			flex-direction: column;
			padding: 1em;
			z-index: 99;
		}
		.nav-links.open {
			display: flex;
		}
	}
</style>

<script is:inline>
	function initMobileMenu() {
		const toggle = document.getElementById('mobile-menu-toggle');
		const nav = document.getElementById('nav-links');
		if (toggle && nav && !toggle._menuInit) {
			toggle._menuInit = true;
			toggle.addEventListener('click', () => {
				nav.classList.toggle('open');
			});
			// Close menu when a link is tapped
			nav.querySelectorAll('a').forEach(function(link) {
				link.addEventListener('click', () => nav.classList.remove('open'));
			});
		}
	}
	// Fire on both initial load and Astro view transitions
	document.addEventListener('DOMContentLoaded', initMobileMenu);
	document.addEventListener('astro:page-load', initMobileMenu);
</script>
