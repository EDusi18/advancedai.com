---
import { CATEGORIES } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-grid">
		<div class="footer-col">
			<h4>Advanced AI</h4>
			<p>AI news, tools, and insights for business leaders navigating the age of artificial intelligence.</p>
		</div>
		<div class="footer-col">
			<h4>Categories</h4>
			<ul>
				{CATEGORIES.map((cat) => (
					<li><a href={`/categories/${cat.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')}`}>{cat}</a></li>
				))}
			</ul>
		</div>
		<div class="footer-col">
			<h4>Links</h4>
			<ul>
				<li><a href="/about">About</a></li>
				<li><a href="/newsletter">Newsletter</a></li>
				<li><a href="/affiliate-disclosure">Affiliate Disclosure</a></li>
				<li><a href="/rss.xml">RSS Feed</a></li>
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Advanced AI. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		background: var(--bg-secondary);
		border-top: 1px solid var(--border);
		padding: 3em 1.5em 2em;
		margin-top: 4em;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2em;
		max-width: 1100px;
		margin: 0 auto;
	}
	.footer-col h4 {
		margin-bottom: 1em;
		color: var(--text);
	}
	.footer-col p {
		color: var(--text-secondary);
		font-size: 0.9em;
		line-height: 1.6;
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-col ul li {
		margin-bottom: 0.5em;
	}
	.footer-col ul li a {
		color: var(--text-secondary);
		font-size: 0.9em;
		text-decoration: none;
	}
	.footer-col ul li a:hover {
		color: var(--accent);
	}
	.footer-bottom {
		max-width: 1100px;
		margin: 2em auto 0;
		padding-top: 2em;
		border-top: 1px solid var(--border);
		text-align: center;
	}
	.footer-bottom p {
		color: var(--text-secondary);
		font-size: 0.85em;
		margin: 0.25em 0;
	}
	.affiliate-note {
		font-size: 0.75em !important;
		opacity: 0.8;
	}
	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
