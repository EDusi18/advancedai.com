---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';

function categorySlug(cat: string) {
	return cat.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Categories | ${SITE_TITLE}`} description="Browse articles by category" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Categories</h1>
			<p class="subtitle">Browse our coverage by topic.</p>
			<div class="categories-grid">
				{CATEGORIES.map((cat) => (
					<a href={`/categories/${categorySlug(cat)}`} class="category-card">
						<h2>{cat}</h2>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.subtitle {
		color: var(--text-secondary);
		margin-bottom: 2em;
	}
	.categories-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}
	.category-card {
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2em;
		text-align: center;
		transition: border-color 0.2s, transform 0.2s;
	}
	.category-card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		text-decoration: none;
	}
	.category-card h2 {
		font-size: 1.25em;
		color: var(--text);
		margin: 0;
	}
	@media (max-width: 768px) {
		.categories-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
