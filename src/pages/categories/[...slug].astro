---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';

export function getStaticPaths() {
	return CATEGORIES.map((cat) => ({
		params: { slug: cat.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-') },
		props: { category: cat },
	}));
}

const { category } = Astro.props;
const posts = (await getCollection('blog'))
	.filter((post) => post.data.category === category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${category} | ${SITE_TITLE}`} description={`Articles about ${category}`} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{category}</h1>
			<p class="subtitle">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
			{posts.length === 0 ? (
				<p class="empty">No articles in this category yet. Check back soon!</p>
			) : (
				<div class="posts-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<Image
									width={400}
									height={200}
									src={post.data.heroImage}
									alt=""
									class="post-card-image"
								/>
							)}
							<div class="post-card-content">
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
								<span class="date"><FormattedDate date={post.data.pubDate} /></span>
							</div>
						</a>
					))}
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.subtitle {
		color: var(--text-secondary);
		margin-bottom: 2em;
	}
	.empty {
		color: var(--text-secondary);
		text-align: center;
		padding: 3em 0;
	}
	.posts-list {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5em;
	}
	.post-card {
		display: block;
		text-decoration: none;
		border-radius: 12px;
		overflow: hidden;
		background: var(--card-bg);
		box-shadow: var(--card-shadow);
		transition: box-shadow 0.3s, transform 0.2s;
	}
	.post-card:hover {
		box-shadow: var(--card-shadow-hover);
		transform: translateY(-2px);
		text-decoration: none;
	}
	.post-card-image {
		width: 100%;
		height: 200px;
		object-fit: cover;
		border-radius: 0;
	}
	.post-card-content {
		padding: 1.25em;
	}
	.post-card-content h2 {
		margin: 0 0 0.25em;
		font-size: 1.2em;
		color: var(--text);
	}
	.post-card-content p {
		color: var(--text-secondary);
		font-size: 0.9em;
	}
	.date {
		color: var(--text-secondary);
		font-size: 0.85em;
	}
	@media (max-width: 768px) {
		.posts-list {
			grid-template-columns: 1fr;
		}
	}
</style>
