---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Editorial Team | ${SITE_TITLE}`}
			description="Meet the AdvancedAI editorial team. Independent analysis and reporting on AI for business leaders."
		/>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<div class="container">
					<h1>AdvancedAI Editorial</h1>
					<p class="subheading">Independent analysis and reporting on AI for business leaders.</p>
					<p class="mission">
						AdvancedAI covers artificial intelligence through a business lens — practical implications,
						honest analysis, and actionable insight for executives and operators. Our editorial team
						brings together expertise in enterprise technology, e-commerce, robotics, and operations.
					</p>
				</div>
			</section>

			<!-- Editorial Standards -->
			<section class="standards">
				<div class="container">
					<h2>Our editorial standards</h2>
					<ul class="standards-list">
						<li>
							<span class="check">✓</span>
							Every factual claim links to a primary source
						</li>
						<li>
							<span class="check">✓</span>
							AI model capabilities are dated — the field moves fast
						</li>
						<li>
							<span class="check">✓</span>
							Predictions are attributed to their source, not asserted as fact
						</li>
						<li>
							<span class="check">✓</span>
							We flag what we don't know rather than papering over gaps
						</li>
						<li>
							<span class="check">✓</span>
							No sponsored content without clear disclosure
						</li>
					</ul>
				</div>
			</section>

			<!-- Our Team -->
			<section class="team">
				<div class="container">
					<h2>Our team</h2>
					<div class="team-grid">
						<div class="team-card">
							<div class="avatar" aria-hidden="true">ED</div>
							<div class="team-info">
								<h3>Erol Dusi</h3>
								<p class="title">Publisher &amp; Editor</p>
								<p class="bio">
									Erol is a serial entrepreneur with businesses spanning e-commerce, data
									infrastructure, robotics, and education technology. He founded AdvancedAI to help
									business leaders cut through AI hype and find what actually works.
								</p>
								<div class="tags">
									<span class="tag">E-commerce</span>
									<span class="tag">AI for Operations</span>
									<span class="tag">Robotics</span>
									<span class="tag">Data Infrastructure</span>
								</div>
								<a href="https://www.linkedin.com/in/erol-dusi/" class="linkedin-link" aria-label="Erol Dusi on LinkedIn">
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
									LinkedIn
								</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Contribute -->
			<section class="contribute">
				<div class="container">
					<h2>Contribute</h2>
					<p>
						We occasionally publish contributions from practitioners with direct, hands-on experience.
						No academics, no PR. If you've deployed AI in a real business and have something concrete
						to say, reach out.
					</p>
					<a href="mailto:editorial@advancedai.com" class="contact-link">editorial@advancedai.com</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.container {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 1.5em;
	}

	/* Hero */
	.hero {
		padding: 4em 0 3em;
		border-bottom: 1px solid var(--border);
	}
	.hero h1 {
		font-size: 2.5em;
		font-weight: 800;
		color: var(--text);
		margin-bottom: 0.4em;
	}
	.hero .subheading {
		font-size: 1.2em;
		color: var(--accent);
		font-weight: 600;
		margin-bottom: 1em;
	}
	.hero .mission {
		font-size: 1.05em;
		color: var(--text-secondary);
		line-height: 1.7;
		max-width: 680px;
	}

	/* Standards */
	.standards {
		padding: 3em 0;
		border-bottom: 1px solid var(--border);
	}
	.standards h2 {
		font-size: 1.5em;
		font-weight: 700;
		margin-bottom: 1.25em;
	}
	.standards-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.85em;
	}
	.standards-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.75em;
		font-size: 1em;
		color: var(--text);
		line-height: 1.5;
	}
	.check {
		color: var(--accent);
		font-weight: 700;
		font-size: 1em;
		flex-shrink: 0;
		margin-top: 0.1em;
	}

	/* Team */
	.team {
		padding: 3em 0;
		border-bottom: 1px solid var(--border);
	}
	.team h2 {
		font-size: 1.5em;
		font-weight: 700;
		margin-bottom: 1.5em;
	}
	.team-grid {
		display: grid;
		gap: 1.5em;
	}
	.team-card {
		display: flex;
		gap: 1.75em;
		align-items: flex-start;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.75em;
		box-shadow: var(--card-shadow);
	}
	.avatar {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		background: var(--accent);
		color: #fff;
		font-weight: 800;
		font-size: 1.35em;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		letter-spacing: 0.02em;
	}
	.team-info h3 {
		font-size: 1.2em;
		font-weight: 700;
		margin: 0 0 0.15em;
	}
	.team-info .title {
		color: var(--accent);
		font-weight: 600;
		font-size: 0.9em;
		margin: 0 0 0.75em;
	}
	.team-info .bio {
		color: var(--text-secondary);
		font-size: 0.95em;
		line-height: 1.65;
		margin-bottom: 1em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 1em;
	}
	.tags .tag {
		background: var(--bg-secondary);
		color: var(--text-secondary);
		border: 1px solid var(--border);
		border-radius: 999px;
		font-size: 0.78em;
		padding: 0.25em 0.75em;
		font-weight: 500;
	}
	.linkedin-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		color: var(--accent);
		font-size: 0.88em;
		font-weight: 600;
		text-decoration: none;
	}
	.linkedin-link:hover {
		text-decoration: underline;
	}

	/* Contribute */
	.contribute {
		padding: 3em 0 4em;
	}
	.contribute h2 {
		font-size: 1.5em;
		font-weight: 700;
		margin-bottom: 0.75em;
	}
	.contribute p {
		color: var(--text-secondary);
		font-size: 1em;
		line-height: 1.7;
		max-width: 640px;
		margin-bottom: 1.25em;
	}
	.contact-link {
		display: inline-block;
		background: var(--accent);
		color: #fff;
		padding: 0.6em 1.4em;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.95em;
		text-decoration: none;
		transition: background 0.2s;
	}
	.contact-link:hover {
		background: var(--accent-dark);
		text-decoration: none;
	}

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 1.9em;
		}
		.team-card {
			flex-direction: column;
			gap: 1.25em;
		}
	}
</style>
