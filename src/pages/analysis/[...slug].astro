---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Newsletter from '../../components/Newsletter.astro';

export async function getStaticPaths() {
	const posts = await getCollection('analysis');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'analysis'>;

const post = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, category, tags } = post.data;
const { Content } = await render(post);
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | Advanced AI`} description={description} article={true} publishDate={pubDate} />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'Article',
			headline: title,
			description: description,
			datePublished: pubDate?.toISOString(),
			dateModified: (updatedDate ?? pubDate)?.toISOString(),
			author: {
				'@type': 'Organization',
				name: 'AdvancedAI Editorial',
				url: 'https://advancedai.com/editorial-team',
			},
			publisher: {
				'@type': 'Organization',
				name: 'AdvancedAI',
				url: 'https://advancedai.com',
				logo: {
					'@type': 'ImageObject',
					url: 'https://advancedai.com/favicon.svg',
				},
			},
			image: heroImage ? new URL(heroImage.src, Astro.url).toString() : 'https://advancedai.com/blog-placeholder-1.jpg',
			mainEntityOfPage: {
				'@type': 'WebPage',
				'@id': new URL(Astro.url.pathname, Astro.site).toString(),
			},
		})} />
		<style>
			.hero-image {
				width: 100%;
				max-width: 900px;
				margin: 0 auto 2em;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 12px;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}
			.post-header {
				margin-bottom: 2em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid var(--border);
			}
			.post-header h1 {
				margin: 0.5em 0 0.25em;
				line-height: 1.15;
			}
			.post-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 1em;
				align-items: center;
				color: var(--text-secondary);
				font-size: 0.9em;
			}
			.last-updated {
				font-style: italic;
				font-size: 0.85em;
				color: var(--text-secondary);
			}
			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.75em;
			}
			.byline {
				font-size: 0.875em;
				color: var(--text-secondary);
				margin-bottom: 1.5em;
				margin-top: 0.5em;
			}
			.byline a {
				color: var(--accent);
				text-decoration: none;
				font-weight: 500;
			}
			.byline a:hover {
				text-decoration: underline;
			}
			.type-badge {
				display: inline-block;
				font-size: 0.7em;
				font-weight: 700;
				letter-spacing: 0.08em;
				padding: 0.2em 0.6em;
				border-radius: 4px;
				text-transform: uppercase;
				background: #f3e8ff;
				color: #7c3aed;
				margin-bottom: 0.5em;
			}
			:global(.dark) .type-badge {
				background: #3b1f5e;
				color: #c4b5fd;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={heroImageAlt || title} />}
				</div>
				<div class="prose">
					<div class="post-header">
						<span class="type-badge">Analysis</span>
						{category && <span class="category-badge">{category}</span>}
						<h1>{title}</h1>
						<div class="post-meta">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="last-updated">
									Updated <FormattedDate date={updatedDate} />
								</span>
							)}
						</div>
						<p class="byline">By <a href="/editorial-team">AdvancedAI Editorial</a></p>
						{tags && tags.length > 0 && (
							<div class="post-tags">
								{tags.map((tag) => <span class="tag">{tag}</span>)}
							</div>
						)}
					</div>

					<Content />

					<Newsletter />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
