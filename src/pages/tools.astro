const SORTED_TOOLS = [...TOOLS].sort((a, b) => {
  if (b.addedDate !== a.addedDate) return b.addedDate.localeCompare(a.addedDate);
  return a.name.localeCompare(b.name);
});

const today = new Date();
const thirtyDaysAgo = new Date(today);
thirtyDaysAgo.setDate(today.getDate() - 30);

const NEW_TOOLS = TOOLS.filter(t => new Date(t.addedDate) >= thirtyDaysAgo)
  .sort((a, b) => b.addedDate.localeCompare(a.addedDate))
  .slice(0, 6);

